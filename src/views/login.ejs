<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/public/fcl1.png" type="image/x-icon">
</head>
<body>
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-header">
        <h1 class="auth-title">Site Access Management</h1>
        <p class="auth-subtitle">Sign in to your account to continue</p>
      </div>
      <div class="auth-body">
        <div id="loginError" class="alert alert-danger" style="display: none;"></div>
        
        <form id="loginForm">
          <div class="form-group">
            <label for="email" class="form-label">Email Address</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              class="form-control" 
              required 
              placeholder="Enter your email"
            >
          </div>
          
          <div class="form-group">
            <label for="password" class="form-label">Password</label>
            <div style="position: relative;">
              <input 
                type="password" 
                id="password" 
                name="password" 
                class="form-control" 
                required 
                placeholder="Enter your password"
                autocomplete="current-password"
              >
              <button type="button" 
                      aria-label="Show password" 
                      title="Show/Hide Password" 
                      data-toggle-password 
                      data-target="password"
                      style="position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%); background: transparent; border: none; cursor: pointer; font-size: 1rem; color: var(--text-secondary);">
                👁
              </button>
            </div>
          </div>
          
          <button type="submit" class="btn btn-primary btn-lg" style="width: 100%; margin-top: 1rem;">
            Sign In
          </button>
        </form>
        
        <!-- <div class="mt-3" style="text-align: center; color: var(--text-secondary); font-size: 0.875rem;">
          <p><strong>Default Accounts:</strong></p>
          <p>Admin: admin@company.com / Admin@123</p>
          <p>Guard: guard@company.com / Guard@123</p>
          <p>Receptionist: receptionist@company.com / Receptionist@123</p>
        </div> -->
      </div>
    </div>
  </div>
  
  <script src="/js/app.js"></script>

  <!-- Site Selection Modal (shown after login) -->
  <div class="modal" id="siteSelectModal" style="z-index: 2000;">
    <div class="modal-dialog" style="max-width: 420px;">
      <div class="modal-content">
        <div class="modal-header" style="border-bottom: 2px solid var(--primary-color);">
          <div>
            <h5 class="modal-title" style="margin: 0;">Select Operating Site</h5>
            <p style="margin: 0.25rem 0 0; font-size: 0.8rem; color: var(--text-secondary);">Choose the site you are operating from for this session</p>
          </div>
        </div>
        <div class="modal-body" style="padding: 1.25rem 1.5rem;">
          <div id="siteSelectError" class="alert alert-danger" style="display:none; margin-bottom: 0.75rem;"></div>
          <div id="siteOptionsList" style="display: flex; flex-direction: column; gap: 0.5rem;"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-primary" id="siteSelectConfirmBtn" disabled>Confirm Site</button>
        </div>
      </div>
    </div>
  </div>
</body>
</html>